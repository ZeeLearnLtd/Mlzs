{
  "name": "mlzs",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "stop": "pm2 stop dist/mlzs/server/main.js",
    "start": " pm2 start dist/mlzs/server/main.js",
    "restart": "pm2 restart dist/mlzs/server/main.js",
    "build": "ng build",
    "test": "ng test",
    "lint": "ng lint",
    "e2e": "ng e2e",
    "serve:prerender": "http-server -g-c-1 dist/mlzs/browser",
    "dev:ssr": "ng run mlzs:serve-ssr",
    "serve:ssr": "node dist/mlzs/server/main.js",
    "build:ssr": "ng build --configuration production && ng run mlzs:server:production",
    "prerender": "ng run mlzs:prerender --routes-file routes.txt && node remove-non-compressed-files.js"
  },
  "private": true,
  "dependencies": {
    "@angular-builders/custom-webpack": "^16.0.1",
    "@angular/animations": "^16.2.12",
    "@angular/cdk": "^16.0.0",
    "@angular/common": "^16.0.0",
    "@angular/compiler": "^16.0.0",
    "@angular/core": "^16.0.0",
    "@angular/forms": "^16.0.0",
    "@angular/material": "^16.0.0",
    "@angular/platform-browser": "^16.0.0",
    "@angular/platform-browser-dynamic": "^16.0.0",
    "@angular/platform-server": "^16.0.0",
    "@angular/router": "^16.0.0",
    "@ng-bootstrap/ng-bootstrap": "^15.1.1",
    "@nguniversal/express-engine": "^16.0.0",
    "@popperjs/core": "^2.11.6",
    "@types/express": "^4.17.8",
    "bootstrap": "^5.2.3",
    "ckeditor4-angular": "^4.0.1",
    "compression": "^1.8.1",
    "cors": "^2.8.5",
    "custom-env": "^2.0.1",
    "dotenv": "^16.0.3",
    "express": "^4.18.2",
    "express-static-gzip": "^2.1.7",
    "helmet": "^8.1.0",
    "jquery": "^3.7.1",
    "lru-cache": "^11.2.1",
    "mssql": "^7.2.0",
    "ng-lazyload-image": "^9.1.3",
    "ngx-panzoom": "^19.0.0",
    "ngx-pinch-zoom": "^2.6.2",
    "ngx-spinner": "^16.0.2",
    "ngx-toastr": "^19.0.0",
    "owl.carousel": "^2.3.4",
    "pm2": "^5.3.0",
    "rxjs": "~7.8.0",
    "swiper": "^11.2.10",
    "tiny-slider": "^2.9.4",
    "ts-loader": "^9.5.1",
    "tslib": "^2.3.0",
    "zone.js": "~0.13.0"
  },
  "devDependencies": {
    "@angular-devkit/build-angular": "^16.0.0",
    "@angular/cli": "^16.0.0",
    "@angular/compiler-cli": "^16.0.0",
    "@nguniversal/builders": "^16.0.0",
    "@types/bootstrap": "^5.2.10",
    "@types/compression": "^1.8.1",
    "@types/jasmine": "~3.8.0",
    "@types/jasminewd2": "~2.0.3",
    "@types/jquery": "^3.5.32",
    "@types/node": "^14.15.0",
    "autoprefixer": "^10.4.21",
    "compression-webpack-plugin": "^10.0.0",
    "http-server": "^14.0.0",
    "jasmine-core": "~3.8.0",
    "jasmine-spec-reporter": "~5.0.0",
    "karma": "~6.3.2",
    "karma-chrome-launcher": "~3.1.0",
    "karma-coverage-istanbul-reporter": "~3.0.2",
    "karma-jasmine": "~4.0.0",
    "karma-jasmine-html-reporter": "^1.5.0",
    "postcss": "^8.5.6",
    "tailwindcss": "^3.4.17",
    "ts-node": "~8.3.0",
    "typescript": "~5.0.4",
    "webpack-cli": "^5.1.4"
  }
